flowchart TD
    A([Start]) --> B[Open Edit modal]
    B --> C[Modify name, email, course, status]
    C --> D[Send PUT request]
    D --> E{Student exists?}
    E -- No --> F[Return not found error]
    F --> G([End])
    E -- Yes --> H{Email conflicts with another student?}
    H -- Yes --> I[Return duplicate email error]
    I --> G
    H -- No --> J[Apply updates through factory]
    J --> K[Save updated record]
    K --> L[Refresh list and show success toast]
    L --> G
